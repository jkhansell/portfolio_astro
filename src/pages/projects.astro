---
// src/pages/projects.astro
import Layout from '@/layouts/Layout.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<Layout title="Projects" description="Explore research projects and software engineering applications. Filter by research or software categories.">
  
  <section class="projects-section section-padding">
    <div class="container animate-fade">
      <div class="section-header">
        <h1 class="page-title"><span class="gradient-text">Projects &amp; Open Source Software</span></h1>
        <p class="section-subtitle">A compilation of research implementations, experimental pipelines, and software tools.</p>
      </div>

      <div class="filter-wrapper">
        <div class="filter-tabs glass-container">
          <button class="filter-btn active" data-filter="all">All Projects</button>
          <button class="filter-btn" data-filter="research">Research</button>
          <button class="filter-btn" data-filter="software">Software</button>
        </div>
      </div>

      <div id="projects-grid" class="grid-3 projects-grid">
        {projects.map(project => (
          /* Match the data-category attribute directly to your markdown frontmatter */
          <div class="project-wrapper animate-slide-up" data-category={project.data.category.toLowerCase()}>
            
            {/* Pass your markdown data parameters + the generated file ID directly to the card */}
            <ProjectCard 
              title={project.data.title}
              description={project.data.description}
              tags={project.data.tags}
              category={project.data.category}
              github={project.data.github}
              paper={project.data.paper}
              demo={project.data.demo}
              slug={project.id} 
            />

          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<script>
  // Client-side project tab filtering script
  const filterButtons = document.querySelectorAll('.filter-btn');
  const projectWrappers = document.querySelectorAll('.project-wrapper');

  if (filterButtons.length > 0 && projectWrappers.length > 0) {
    filterButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const button = e.currentTarget as HTMLButtonElement;
        const filter = button.getAttribute('data-filter');

        filterButtons.forEach(b => b.classList.remove('active'));
        button.classList.add('active');

        projectWrappers.forEach(wrapper => {
          const projectWrapper = wrapper as HTMLElement;
          const category = projectWrapper.getAttribute('data-category');

          if (filter === 'all' || category === filter) {
            projectWrapper.style.display = 'block';
            projectWrapper.style.animation = 'none';
            void projectWrapper.offsetHeight; // Force layout reflow
            projectWrapper.style.animation = 'slideUp 0.3s ease-out forwards';
          } else {
            projectWrapper.style.display = 'none';
          }
        });
      });
    });
  }
</script>


<style>
  .page-title {
    text-align: center;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .gradient-text {
    color: var(--accent);
  }

  .section-header {
    margin-bottom: 3rem;
    text-align: center;
  }

  .section-subtitle {
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Filter Styling */
  .filter-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 3.5rem;
  }

  .filter-tabs {
    display: inline-flex;
    padding: 0.35rem;
    border-radius: 12px;
    gap: 0.25rem;
    background: var(--bg-glass);
    border: 1px solid var(--border-glass);
  }

  .filter-btn {
    background: transparent;
    border: none;
    color: var(--text-muted);
    padding: 0.6rem 1.25rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    font-family: var(--font-title);
    transition: var(--transition-fast);
  }

  .filter-btn:hover {
    color: var(--text-primary);
  }

  .filter-btn.active {
    color: var(--text-primary);
    background: var(--bg-glass-hover);
    box-shadow: var(--shadow-sm);
  }

  /* Grid details - aligned with publication width */
  .projects-grid {
    margin-top: 1.5rem;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    display: grid;
    gap: 1.5rem;
    /* Optional: Use auto-fill to make it responsive */
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }

  .project-wrapper {
    animation: slideUp var(--transition-normal) forwards;
  }
</style>