---
import Layout from '@/layouts/Layout.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import PublicationItem from '@/components/PublicationItem.astro';
import ConferenceItem from '@/components/ConferenceItem.astro';
import publicationsData from '@/data/publications.json';


const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

// Scientific computing highlight data
const featuredProject = {
  title: "Physics-Informed Neural Architecture Search",
  description: "Investigating safety bounds and conservation-law constraints for automated deep neural network design in physical systems.",
  tags: ["PyTorch", "AutoML", "Scientific ML", "Physics"],
  category: "Research",
  github: "https://github.com",
  paper: `${baseUrl}/publications`
};

const featuredPublication = {
  title: "Towards Certifiably Safe Neural Architecture Search",
  authors: "Alex Carter, Sarah Jenkins, David Cole",
  venue: "Journal of Machine Learning Research (JMLR), 2025",
  year: 2025,
  doi: "10.1007/s10462-024-00123-x",
  pdf: "https://arxiv.org",
  bibtex: `@article{carter2025certifiably,\n  title={Towards Certifiably Safe Neural Architecture Search},\n  author={Carter, Alex and Jenkins, Sarah and Cole, David},\n  journal={Journal of Machine Learning Research},\n  volume={26},\n  number={12},\n  pages={1--35},\n  year={2025}\n}`,
  abstract: "Automated search algorithms for neural networks often select architectures that maximize average-case test accuracy, frequently neglecting adversarial robustness or physical safety boundary constraints. In this work, we propose a certifiable safety constraint..."
};

const upcomingTalk = {
  title: "Robustness Bounds in AutoML Systems for Scientific Computing",
  event: "International Conference on Machine Learning (ICML)",
  date: "July 24, 2026",
  location: "Vienna, Austria",
  role: "Keynote Speaker",
  link: "https://icml.cc"
};

const { preprints, journals, conferences } = publicationsData;

// 1. Calculate publication count dynamically from your JSON arrays
const totalPublications = preprints.length + journals.length + conferences.length;

// 2. Keep metrics that platforms can't track static here
const academicStats = {
  citations: 2, // Update manually when you hit milestone peaks
  coreHours: "2", 
  ossPackages: 4
};

---
<Layout title="Home" description="Scientific Computing and High-Performance Machine Learning portfolio of Alex Carter. Focusing on Physics-Informed ML, AutoML, and robust computational systems.">
  
  <!-- Hero Section -->
  <section class="hero-section section-padding">
    <div class="container hero-grid">
      <div class="hero-content animate-slide-up">
        <span class="badge badge-accent hero-badge">Scientific Computing &amp; HPC</span>
        <h1 class="hero-title">
          Engineering <span class="gradient-text">Safe Computational Models</span> at Scale
        </h1>
        <p class="hero-bio">
          
        </p>
        <div class="hero-actions">
          <a href={`${baseUrl}/projects`} class="btn btn-primary">
            Explore Projects
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
          <a href={`${baseUrl}/publications`} class="btn btn-secondary">
            Read Publications
          </a>
        </div>
      </div>
      
      <!-- Premium Decorative SVG Graphic - Connected Nodes -->
      <div class="hero-visual animate-fade animation-delay-200">
        <div class="visual-container glass-container">
          <img 
            src="public/images/amr.gif" 
            alt="High-Performance Computing Simulation Loop" 
            class="hero-gif"
            loading="eager" 
          />
        </div>
      </div>
    </div>
  </section>

<!-- Metrics / Stats Banner -->
<section class="stats-section">
  <div class="container">
    <div class="stats-grid glass-container">
      <div class="stat-item">
        <!-- Renders dynamically from your data file -->
        <span class="stat-number">{totalPublications}+</span>
        <span class="stat-label">Publications</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">{academicStats.citations}</span>
        <span class="stat-label">Citations</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">{academicStats.coreHours}</span>
        <span class="stat-label">Codes Optimized for HPC Hardware</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">{academicStats.ossPackages}</span>
        <span class="stat-label">OSS Packages</span>
      </div>
    </div>
  </div>
</section>

  <!-- Highlights Showcase -->
  <section class="highlights-section section-padding">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Research &amp; Work Highlights</h2>
        <p class="section-subtitle">A quick glance at my latest contributions and upcoming events.</p>
      </div>

      <div class="highlights-grid">
        <!-- Project highlight -->
        <div class="highlight-col">
          <div class="col-header">
            <h3 class="col-title">Latest Project</h3>
            <a href={`${baseUrl}/projects`} class="view-all-link">All Projects &rarr;</a>
          </div>
          <ProjectCard {...featuredProject} />
        </div>

        <!-- Publication highlight -->
        <div class="highlight-col">
          <div class="col-header">
            <h3 class="col-title">Featured Publication</h3>
            <a href={`${baseUrl}/publications`} class="view-all-link">All Publications &rarr;</a>
          </div>
          <PublicationItem {...featuredPublication} />
        </div>
      </div>
      
      <!-- Upcoming talk highlight -->
      <div class="timeline-highlight">
        <div class="col-header">
          <h3 class="col-title">Next Speaking Engagement</h3>
          <a href={`${baseUrl}/conferences`} class="view-all-link">All Presentations &rarr;</a>
        </div>
        <div class="timeline select-none">
          <ConferenceItem {...upcomingTalk} />
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Hero styles */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1.2fr 0.8fr;
    }
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-badge {
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .gradient-text {
    color: var(--accent);
  }

  .hero-bio {
    font-size: 1.15rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-visual {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .visual-container {
    width: 100%;
    max-width: 400px;
    aspect-ratio: 1;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(42, 59, 66, 0.2);
    transition: background-color var(--transition-normal);
  }

  html.light-theme .visual-container {
    background: rgba(0, 0, 0, 0.02);
  }

  .hero-svg {
    width: 100%;
    height: 100%;
    color: var(--primary);
  }

  /* Stats styles */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    padding: 2.5rem 1.5rem;
    gap: 2rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .stat-number {
    font-family: var(--font-title);
    font-size: 2.5rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--text-primary) 0%, var(--text-secondary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .stat-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Highlights Section */
  .section-header {
    margin-bottom: 3.5rem;
    text-align: center;
  }

  .section-title {
    margin-bottom: 0.75rem;
  }

  .section-subtitle {
    color: var(--text-secondary);
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 1024px) {
    .highlights-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .highlight-col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .col-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .col-title {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .view-all-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--primary);
  }

  .view-all-link:hover {
    color: var(--accent);
  }

  .timeline-highlight {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    border-top: 1px solid var(--border-glass);
    padding-top: 3rem;
    transition: border-color var(--transition-normal);
  }

  .hero-gif-container {
    padding: 0 !important; /* Removes default glass-container padding so the image goes flush to the edges */
    overflow: hidden;      /* Ensures the image doesn't break the rounded corners of the glass container */
    aspect-ratio: 1 / 1;   /* Keeps the container a perfect square (adjust this if your GIF is rectangular, like 16/9) */
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-gif {
    width: 100%;
    height: 100%;
    object-fit: cover;     /* Zooms the GIF slightly to fill the box without squishing it */
    display: block;
  }
</style>


