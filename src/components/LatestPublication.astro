---
interface Props {
  title: string;
  authors: string;
  venue: string;
  year: number;
  doi?: string;
  pdf?: string;
  bibtex?: string;
  abstract?: string;
}

const { title, authors, venue, year, doi, pdf, bibtex, abstract } = Astro.props;

import { SITE_METADATA } from "@/config";

// Underline "Alex Carter" or "Carter, A." in the authors list for academic visibility
const formatAuthors = (authorStr: string) => {
  const target = SITE_METADATA.name;
  if (!authorStr.includes(target)) return authorStr;
  
  // Split and replace to avoid raw HTML injections by strictly isolating the name
  return authorStr.split(target).reduce((acc: any[], part, idx, arr) => {
    if (idx === arr.length - 1) {
      acc.push(part);
    } else {
      acc.push(part, { isSelf: true, name: target });
    }
    return acc;
  }, []);
};

const formattedAuthors = formatAuthors(authors);
---

<div class="glass-container publication-item">
  <div class="pub-body">
    <div class="pub-main">
      <span class="pub-year">{year}</span>
      <h3 class="pub-title">{title}</h3>
      <p class="pub-authors">
        {typeof formattedAuthors === 'string' ? (
          formattedAuthors
        ) : (
          formattedAuthors.map(node => 
            typeof node === 'string' ? node : <strong><u>{node.name}</u></strong>
          )
        )}
      </p>
      <p class="pub-venue"><em>{venue}</em></p>
    </div>

    <!-- Action buttons -->
    <div class="pub-actions">
      {pdf && (
        <a href={pdf} target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-xs">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          PDF
        </a>
      )}
      {doi && (
        <a href={`https://doi.org/${doi}`} target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-xs">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
          DOI
        </a>
      )}
      {bibtex && (
        <button class="btn btn-secondary btn-xs copy-bibtex-btn" data-bibtex={bibtex}>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          Copy BibTeX
        </button>
      )}
    </div>

    <!-- Abstract and BibTeX drawer using HTML5 Details -->
    {abstract && (
      <details class="pub-details">
        <summary class="details-summary">Show Abstract</summary>
        <div class="details-content">
          <p>{abstract}</p>
        </div>
      </details>
    )}

    {bibtex && (
      <details class="pub-details">
        <summary class="details-summary">Show BibTeX</summary>
        <div class="details-content bibtex-content">
          <pre><code>{bibtex}</code></pre>
        </div>
      </details>
    )}
  </div>
</div>

<script>
  // Setup clipboard copy for BibTeX securely and efficiently
  const copyButtons = document.querySelectorAll('.copy-bibtex-btn');
  copyButtons.forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const button = e.currentTarget as HTMLButtonElement;
      const bibtexText = button.getAttribute('data-bibtex');
      if (bibtexText) {
        try {
          await navigator.clipboard.writeText(bibtexText);
          const originalText = button.textContent;
          button.textContent = 'Copied!';
          button.classList.add('copied');
          setTimeout(() => {
            button.textContent = originalText;
            button.classList.remove('copied');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy text: ', err);
        }
      }
    });
  });
</script>

<style>
    .publication-item {
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
    padding: 1.5rem; /* Matches Project Card spacing */
    border-radius: 16px;
    background: var(--bg-glass);
    border: 1px solid var(--border-glass);
    transition: border-color var(--transition-normal), box-shadow var(--transition-normal), transform var(--transition-normal);
    }

    .publication-item:hover {
    transform: translateY(-4px);
    border-color: var(--border-glass-hover);
    box-shadow: var(--shadow-glow);
    }

    .pub-body {
    flex-grow: 1; /* Pushes action buttons to the bottom */
    margin-bottom: 1.5rem;
    }

    .pub-year {
    font-family: var(--font-title);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
    display: block;
    }

    .pub-title {
    font-size: 1.25rem; /* Matches project-title */
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.5rem 0;
    line-height: 1.4;
    }

    .pub-authors {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
    }

    .pub-venue {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    }

    /* Actions area stays at the bottom */
    .pub-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: auto; 
    position: relative;
    z-index: 5;
    }

    .btn-xs {
    padding: 0.5rem 1rem; /* Unified padding */
    font-size: 0.85rem;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--bg-main);
    border: 1px solid var(--border-glass);
    color: var(--text-primary);
    transition: var(--transition-fast);
    }

    .btn-xs:hover {
    background: var(--bg-glass-hover);
    }

  .copy-bibtex-btn.copied {
    background: var(--primary-glow);
    border-color: var(--primary);
    color: var(--primary);
  }

  /* HTML5 Details / Summary Customizations */
  .pub-details {
    margin-top: 0.5rem;
    border-top: 1px solid var(--border-glass);
    padding-top: 0.5rem;
  }

  .details-summary {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-muted);
    cursor: pointer;
    user-select: none;
    padding: 0.25rem 0;
    width: fit-content;
    transition: var(--transition-fast);
  }

  .details-summary:hover {
    color: var(--primary);
  }

  .details-content {
    padding: 1rem 0 0.5rem 0;
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

    .bibtex-content pre {
    background: var(--bg-main);
    padding: 1rem;
    border-radius: 6px;
    border: 1px solid var(--border-glass);
    
    /* Force wrapping */
    white-space: pre-wrap;       /* CSS3 */
    white-space: -moz-pre-wrap;  /* Mozilla, since 1999 */
    white-space: -pre-wrap;      /* Opera 4-6 */
    white-space: -o-pre-wrap;    /* Opera 7 */
    word-wrap: break-word;       /* Internet Explorer 5.5+ */
    
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--text-secondary);
    }
</style>